{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "soulbot/cache/conversation_context",
  "title": "Conversation context schema",
  "description": "Per-engine conversation_context.json — sliding window of completed/active turns. Written by prepare_execution_context() + _finalize_pending_turns().",
  "type": "object",
  "required": ["turns"],
  "properties": {
    "max_turns": {
      "type": "integer",
      "minimum": 1
    },
    "ttl_hours": {
      "type": "integer",
      "minimum": 1
    },
    "turns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["turn_id", "timestamp", "status"],
        "properties": {
          "turn_id": {
            "type": "integer",
            "minimum": 1
          },
          "timestamp": {
            "type": "string",
            "description": "ISO 8601 datetime."
          },
          "turn_type": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "in_progress",
              "completed",
              "abandoned",
              "failed",
              "waiting_user"
            ]
          },
          "user_message": {
            "type": "string"
          },
          "ai_response": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
